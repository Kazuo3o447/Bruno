# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=bruno
DB_PASS=bruno_secret
DB_NAME=bruno_trading

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# ═══════════════════════════════════════════════
# Bruno Trading Bot — Environment Variables
# ═══════════════════════════════════════════════
# NIEMALS committen. In .gitignore prüfen.
# .env.example hat dieselbe Struktur, aber leere Werte.

# ───────────────────────────────────────────────
# DATEN-APIs (kostenlos, kein Minimum)
# ───────────────────────────────────────────────
FRED_API_KEY=b1ebff9d70c86afe6611df19acb06484
CRYPTOPANIC_API_KEY=

# ───────────────────────────────────────────────
# ON-CHAIN (Glassnode Free — Phase C)
# ───────────────────────────────────────────────
GLASSNODE_API_KEY=

# ───────────────────────────────────────────────
# EXECUTION — BYBIT
# Demo:  BYBIT_MODE=demo   → api-demo.bybit.com
# Live:  BYBIT_MODE=live   → api.bybit.com
# ───────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_SECRET=
BYBIT_MODE=demo          # NIEMALS auf live ohne bestandenen Backtest

# ───────────────────────────────────────────────
# BEZAHLT (nach 4 Wochen stabilem DRY_RUN)
# ───────────────────────────────────────────────
COINGLASS_API_KEY=

# ───────────────────────────────────────────────
# NOTIFICATIONS (Phase B)
# ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ───────────────────────────────────────────────
# SYSTEM
# ───────────────────────────────────────────────
DRY_RUN=true             # Hardware-Block — NIEMALS auf false ohne Backtest
OLLAMA_HOST=http://host.docker.internal:11434

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Binance API (nur noch für Daten, nicht für Execution)
# Hinweis: Bybit ist neue Execution-Börse (siehe BYBIT_* oben)
BINANCE_API_KEY=
BINANCE_SECRET=
