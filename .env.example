# ═══════════════════════════════════════════════════════════
# Bruno Trading Bot — Environment Variables Template
# ═══════════════════════════════════════════════════════════
# DIESE DATEI: Ist im Repository (keine echten Keys)
# .env (lokal): Enthält echte Keys — NIEMALS committen
# ═══════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────
# DATENBANK
# ───────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=bruno
DB_PASS=bruno_secret
DB_NAME=bruno_trading

# ───────────────────────────────────────────────────────────
# REDIS
# ───────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ───────────────────────────────────────────────────────────
# LLM (Phase C — Provider-Architektur)
# ───────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_HOST=http://host.docker.internal:11434
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ───────────────────────────────────────────────────────────
# DATEN-APIs (kostenlos — Phase A)
# ───────────────────────────────────────────────────────────
FRED_API_KEY=
CRYPTOPANIC_API_KEY=
# Binance REST: kein Key nötig für öffentliche Marktdaten
# Deribit Public: kein Key nötig (/public/ Endpunkte)

# ───────────────────────────────────────────────────────────
# API FIXES — Rate Limit & Fallback Lösungen
# ───────────────────────────────────────────────────────────
# Alpha Vantage (NDX Fallback) — 25 req/day kostenlos
ALPHA_VANTAGE_API_KEY=

# Reddit OAuth (App-Only, kein User-Login)
# App erstellen: https://www.reddit.com/prefs/apps → "script app"
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# StockTwits (optional — leer lassen = wird übersprungen)
STOCKTWITS_API_KEY=

# HuggingFace Token (schnellere Model-Downloads)
# Token erstellen: https://huggingface.co/settings/tokens → Read-only
HF_TOKEN=

# ───────────────────────────────────────────────────────────
# EXECUTION — BYBIT (Phase D)
# demo  → api-demo.bybit.com  (50.000 USDT simuliert, echte Orderbücher)
# live  → api.bybit.com       (echtes Kapital — NUR nach Backtest)
# ───────────────────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_SECRET=
BYBIT_MODE=demo
# LIVE_TRADING_APPROVED=true nur nach expliziter Freigabe und bestandenem Backtest
LIVE_TRADING_APPROVED=false

# ───────────────────────────────────────────────────────────
# ON-CHAIN Daten (Phase C)
# ───────────────────────────────────────────────────────────
GLASSNODE_API_KEY=

# ───────────────────────────────────────────────────────────
# BEZAHLTE APIs (nach 4 Wochen stabilem DRY_RUN)
# ───────────────────────────────────────────────────────────
COINGLASS_API_KEY=

# ───────────────────────────────────────────────────────────
# NOTIFICATIONS (Phase B)
# ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ───────────────────────────────────────────────────────────
# SYSTEM
# ───────────────────────────────────────────────────────────
DRY_RUN=true
# EISERNE REGEL: DRY_RUN=false NUR nach bestandenem Backtest (Phase G)

# Binance (nur für Live-Trading nötig, Marktdaten sind ohne Key verfügbar)
BINANCE_API_KEY=
BINANCE_SECRET=
