FROM node:20-alpine

# Build arguments für Umgebungsvariablen
ARG NEXT_PUBLIC_API_URL=http://api-backend:8000
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

WORKDIR /app

COPY package.json ./
RUN npm install

# Copy source files
COPY src/ ./src/
COPY next.config.js ./
COPY next-env.d.ts ./
COPY tsconfig.json ./

# Build the application with environment variables
RUN npm run build

EXPOSE 3000

CMD ["npx", "next", "start"]
