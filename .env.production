# ═══════════════════════════════════════════════════════════
# Bruno Trading Bot — PRODUCTION Environment Variables
# ═══════════════════════════════════════════════════════════
# WARNUNG: Diese Datei enthält echte API Keys und Passwörter
# NIEMALS in Git committen oder teilen!
# ═══════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────
# DATENBANK (Production)
# ───────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=bruno_prod
DB_PASS=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN
DB_NAME=bruno_production

# ───────────────────────────────────────────────────────────
# REDIS (Production)
# ───────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN

# ───────────────────────────────────────────────────────────
# LLM PROVIDER (Production)
# ───────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_HOST=http://host.docker.internal:11434
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_PRODUCTION_KEY
GROQ_API_KEY=YOUR_GROQ_PRODUCTION_KEY

# ───────────────────────────────────────────────────────────
# DATEN-APIs (Production — ECHTE KEYS ERFORDERLICH)
# ───────────────────────────────────────────────────────────
FRED_API_KEY=YOUR_FRED_PRODUCTION_API_KEY
CRYPTOCOMPARE_API_KEY=YOUR_CRYPTOCOMPARE_PRODUCTION_API_KEY
COINMARKETCAP_API_KEY=YOUR_COINMARKETCAP_PRODUCTION_API_KEY

# ───────────────────────────────────────────────────────────
# API FIXES — Production Keys
# ───────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_PRODUCTION_KEY
REDDIT_CLIENT_ID=YOUR_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=YOUR_REDDIT_CLIENT_SECRET
STOCKTWITS_API_KEY=YOUR_STOCKTWITS_API_KEY
HF_TOKEN=YOUR_HUGGINGFACE_READ_ONLY_TOKEN

# ───────────────────────────────────────────────────────────
# EXECUTION — BYBIT (Production)
# ───────────────────────────────────────────────────────────
BYBIT_API_KEY=YOUR_BYBIT_PRODUCTION_API_KEY
BYBIT_SECRET=YOUR_BYBIT_PRODUCTION_SECRET
BYBIT_MODE=demo  # Start mit Demo, nach Backtest: live
LIVE_TRADING_APPROVED=false  # NUR nach erfolgreichem Backtest = true

# ───────────────────────────────────────────────────────────
# ON-CHAIN Daten (Production)
# ───────────────────────────────────────────────────────────
GLASSNODE_API_KEY=YOUR_GLASSNODE_PRODUCTION_API_KEY
COINGLASS_API_KEY=YOUR_COINGLASS_PRODUCTION_API_KEY

# ───────────────────────────────────────────────────────────
# NOTIFICATIONS (Production)
# ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ───────────────────────────────────────────────────────────
# SYSTEM (Production)
# ───────────────────────────────────────────────────────────
DRY_RUN=true  # IMMER true in Production!
PAPER_TRADING_ONLY=true  # IMMER true für Sicherheit!

# ───────────────────────────────────────────────────────────
# PRODUCTION SECURITY SETTINGS
# ───────────────────────────────────────────────────────────
# Zusätzliche Sicherheit für Production
ENVIRONMENT=production
LOG_LEVEL=INFO
ENABLE_METRICS=true
ENABLE_HEALTH_CHECKS=true

# ───────────────────────────────────────────────────────────
# BACKUP & MONITORING
# ───────────────────────────────────────────────────────────
BACKUP_SCHEDULE=daily
METRICS_PORT=9090
HEALTH_CHECK_PORT=8080
